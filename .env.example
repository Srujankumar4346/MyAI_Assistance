# NOVA_X Environment Configuration (Example)
# Copy this file to .env and configure as needed.

# ==========================================
# Core Platform
# ==========================================
ENVIRONMENT=development
# Secret key used for JWT signing (Generate a secure random string for production)
SECRET_KEY=super_secret_dev_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==========================================
# Database (PostgreSQL)
# ==========================================
# If running via Docker Compose, use postgresql://novax:novaxpass@postgres:5432/novax_db
DATABASE_URL=sqlite:///./novax.db

# ==========================================
# AI Models (Ollama)
# ==========================================
# If running via Docker Compose (profile ai/full), use http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=llama3

# ==========================================
# Storage Paths (Local Development)
# ==========================================
STORAGE_ROOT=./data
LOG_LEVEL=INFO
